FrameWidgetClass rootFrame {
 position 0 0
 size 1 1
 hexactpos 0
 vexactpos 0
 hexactsize 0
 vexactsize 0
 scriptclass "ConfirmationWindow"
 {
  PanelWidgetClass ConfirmationWindow {
   visible 1
   disabled 0
   ignorepointer 1
   color 0.1569 0.1569 0.1569 1
   size 0.216 0.259
   halign center_ref
   valign center_ref
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   draggable 1
   style rover_sim_colorable
   {
    TextWidgetClass Title {
     ignorepointer 1
     position 0 0.075
     size 1 0.2
     halign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     text "#str_inventorymanagermenu_areyousure"
     font "gui/fonts/metron"
     "text halign" center
     "text valign" center
    }
    MultilineTextWidgetClass Action {
     ignorepointer 1
     position 0 0
     size 0.9 0.38
     halign center_ref
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style DayZNormal
     text "Delete Item: AK-47"
     font "gui/fonts/metron"
     "text halign" center
     "text valign" center
     wrap 1
    }
    ButtonWidgetClass Yes {
     color 0.102 0.7373 0.1529 1
     position -0.25 0.05
     size 0.4 0.17
     halign center_ref
     valign bottom_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style Editor
     text "Yes"
     font "gui/fonts/metron"
    }
    ButtonWidgetClass No {
     color 0.8902 0.1333 0.1098 1
     position 0.25 0.05
     size 0.4 0.17
     halign center_ref
     valign bottom_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style Editor
     text "No"
     font "gui/fonts/metron"
    }
    PanelWidgetClass border_right {
     ignorepointer 1
     color 0.0039 0.0039 0.0039 1
     position 0.5 0
     size 0.01 1
     halign center_ref
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style rover_sim_colorable
    }
    PanelWidgetClass border_left {
     ignorepointer 1
     color 0.0039 0.0039 0.0039 1
     position -0.5 0
     size 0.01 1
     halign center_ref
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style rover_sim_colorable
    }
    PanelWidgetClass border_bottom {
     ignorepointer 1
     color 0.0039 0.0039 0.0039 1
     position 0 0.5
     size 1 0.02
     halign center_ref
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style rover_sim_colorable
    }
    PanelWidgetClass border_top {
     ignorepointer 1
     color 0.0039 0.0039 0.0039 1
     position 0 -0.5
     size 1 0.02
     halign center_ref
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style rover_sim_colorable
    }
   }
  }
 }
}